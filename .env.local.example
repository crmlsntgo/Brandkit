# Google Gemini API key — get a key at https://aistudio.google.com/app/apikey
# Free tier is generous (no credit card required as of writing).
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase — optional. Without these, the app falls back to localStorage-only
# history (no sign-in, no cloud sync). Get credentials at supabase.com.
# After creating a project, run supabase/schema.sql in the SQL Editor.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
